# Cloud / GCP mode
INFRA_MODE=cloud

# Cloud SQL or external PostgreSQL connection.
# For Cloud SQL Unix socket, DB_HOST should look like:
# /cloudsql/project-id:region:instance-name
DB_USER=excel
DB_PASSWORD=change_me_strong_password
DB_NAME=excel_onboarding
DB_HOST=/cloudsql/project-id:region:instance-name
DB_PORT=5432

# GCP Cloud Tasks.
GCP_PROJECT_ID=project-id
GCP_LOCATION=asia-northeast3
GCP_TASKS_QUEUE_NAME=excel-export-queue
BACKEND_URL=https://your-backend-cloud-run-url
TASKS_SERVICE_ACCOUNT_EMAIL=tasks-invoker@project-id.iam.gserviceaccount.com

# GCP Cloud Storage.
GCP_STORAGE_BUCKET_NAME=your-excel-export-bucket

# Only used by local storage mode. Cloud mode returns GCS signed URLs.
EXCEL_DOWNLOAD_PREFIX=/files

# Optional. Same webhook can be used in both cloud and local modes.
DISCORD_WEBHOOK_URL=

# Max times a single job is claimed before it is left permanently FAILED.
# Guards against Cloud Tasks retrying an always-failing job forever. Default: 3.
MAX_ATTEMPTS=3

# A PROCESSING job whose started_at is older than this (seconds) is treated as
# dead and may be re-claimed by the next attempt. Keep >= dispatch_deadline
# (1800s) so a legitimately long-running export is not stolen. Default: 1800.
PROCESSING_LEASE_SECONDS=1800

# DB connection pool / robustness. Keep instances × (POOL_SIZE+MAX_OVERFLOW)
# under Cloud SQL max_connections. pool_pre_ping is always on (recycles stale
# Cloud SQL connections). STATEMENT_TIMEOUT_MS=0 disables the server-side query
# timeout (default); set >0 to abort runaway queries.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=0

# Protects POST /create. When set, requests must send header:
#   X-API-Key: <this value>
# Strongly recommended in cloud. Leave empty only for throwaway environments.
API_KEY=

# Verify the OIDC token on the Cloud Tasks callback (POST /tasks/excel).
# Keep "true" in production. Set "false" only to temporarily debug OIDC setup.
VERIFY_TASK_OIDC=true

# Runtime port. Cloud Run usually injects PORT automatically.
PORT=8000
