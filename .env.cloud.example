# Cloud / GCP mode
INFRA_MODE=cloud

# Cloud SQL or external PostgreSQL connection.
# For Cloud SQL Unix socket, DB_HOST should look like:
# /cloudsql/project-id:region:instance-name
DB_USER=excel
DB_PASSWORD=change_me_strong_password
DB_NAME=excel_onboarding
DB_HOST=/cloudsql/project-id:region:instance-name
DB_PORT=5432

# GCP Cloud Tasks.
GCP_PROJECT_ID=project-id
GCP_LOCATION=asia-northeast3
GCP_TASKS_QUEUE_NAME=excel-export-queue
BACKEND_URL=https://your-backend-cloud-run-url
TASKS_SERVICE_ACCOUNT_EMAIL=tasks-invoker@project-id.iam.gserviceaccount.com

# GCP Cloud Storage.
GCP_STORAGE_BUCKET_NAME=your-excel-export-bucket

# Only used by local storage mode. Cloud mode returns GCS signed URLs.
EXCEL_DOWNLOAD_PREFIX=/files

# Optional. Same webhook can be used in both cloud and local modes.
DISCORD_WEBHOOK_URL=

# Runtime port. Cloud Run usually injects PORT automatically.
PORT=8000
