# On-premise / Docker Compose mode
INFRA_MODE=local

# Host port exposed by the frontend container.
FRONTEND_PORT=3000

# PostgreSQL container credentials.
DB_USER=excel
DB_PASSWORD=change_me_strong_password
DB_NAME=excel_onboarding
EXCEL_DOWNLOAD_PREFIX=/files

# Optional. Leave empty if webhook notifications are not used.
DISCORD_WEBHOOK_URL=

# Max times a single job is claimed before it is left permanently FAILED.
# Guards against infinite retries of a job that always fails. Default: 3.
MAX_ATTEMPTS=3

# Protects POST /create. When set, requests must send header:
#   X-API-Key: <this value>
# Leave empty to disable auth (dev only; the backend logs a warning at startup).
API_KEY=
